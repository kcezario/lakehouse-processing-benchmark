# =========================================================
# S3 / OBJECT STORAGE
# =========================================================
PRODUCT=lakehouse_benchmark
ENVIRONMENT=dev

# Optional path prefix inside the bucket before raw-layer keys.
S3_STAGING_KEY_ROOT=
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=YOUR_ACCESS_KEY
S3_SECRET_KEY=YOUR_SECRET_KEY
S3_REGION=us-east-1

# Logs are uploaded to s3://<bucket>/<S3_LOGS_PREFIX>/YYYY-MM-DD/...
S3_LOGS_PREFIX=logs/lakehouse_benchmark
LOG_S3_ENABLED=true


# =========================================================
# TRINO
# =========================================================
TRINO_HOST=localhost
TRINO_PORT=8443
TRINO_USER=benchmark_user
TRINO_PASSWORD=YOUR_TRINO_PASSWORD
TRINO_HTTP_SCHEME=https
TRINO_CERT=/path/to/your/trino-ca.crt
TRINO_VERIFY=true


# =========================================================
# DATASET / PIPELINE
# =========================================================
DATASET=transactions
EXCHANGE_RATE_USD_BRL=5.03


# =========================================================
# TRANSFORMATION ENGINE
# =========================================================
# options: python | pandas | spark
TRANSFORMATION_ENGINE=pandas


# =========================================================
# SPARK
# =========================================================
SPARK_CLIENT_URL=http://localhost:8080/submit
SPARK_TIMEOUT_SECONDS=300
SPARK_CONNECT_TIMEOUT_SECONDS=15
SPARK_SUBMIT_READ_TIMEOUT_SECONDS=120
SPARK_POLL_INTERVAL_SECONDS=3
SPARK_POLL_TIMEOUT_SECONDS=600

# Required when TRANSFORMATION_ENGINE=spark
NESSIE_URI=http://localhost:19120/api/v1
NESSIE_WAREHOUSE=s3a://bkt-lakehouse-benchmark-dev-mda/iceberg
NESSIE_REF=main
NESSIE_AUTHENTICATION_TYPE=NONE
SPARK_ICEBERG_CATALOG_NAME=nessie
NESSIE_IO_IMPL=org.apache.iceberg.hadoop.HadoopFileIO


# =========================================================
# BENCHMARK
# =========================================================
BENCHMARK_ENABLED=true
BENCHMARK_ROWS=5000,10000,50000,100000
BENCHMARK_ENGINES=python,pandas,spark
BENCHMARK_TIMEOUT_SECONDS=120


# =========================================================
# LOGGING
# =========================================================
LOG_LEVEL=INFO
LOG_FILE_NAME=benchmark.log